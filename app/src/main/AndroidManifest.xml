        <activity android:name=".FoodDetailActivity" />
        <activity android:name=".NearbyMapActivity" />
        <activity android:name=".ClaimConfirmActivity" />
        <activity android:name=".MyClaimsActivity" />
        <activity android:name=".NGODashboardActivity" />
