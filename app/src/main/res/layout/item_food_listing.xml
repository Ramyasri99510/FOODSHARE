<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="2dp"
    app:strokeColor="@color/gray_light"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/textFoodEmoji"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="#F3F4F6"
            android:gravity="center"
            android:text="🍚"
            android:textSize="32sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textFoodName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Food Name"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/textFoodEmoji"
            app:layout_constraintTop_toTopOf="@id/textFoodEmoji" />

        <TextView
            android:id="@+id/textDonorInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Donor: Rahul | T Nagar"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/textFoodName"
            app:layout_constraintTop_toBottomOf="@id/textFoodName" />

        <!-- India-First Logic: Displaying both Weight and Portions -->
        <TextView
            android:id="@+id/textQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#E0F2F1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Qty: 5kg"
            android:textColor="#00796B"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/textFoodName"
            app:layout_constraintTop_toBottomOf="@id/textDonorInfo" />

        <!-- Urgency Badge: The "Happiness & Urgency" USP -->
        <TextView
            android:id="@+id/textExpiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFF3E0"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Smart Alert: 2h left"
            android:textColor="#E65100"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/textQuantity"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/textQuantity" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>